@page
@model PeminjamanAlat.Pages.Petugas.DaftarAlatModel
@{
    Layout = "_LayoutPetugas";
    ViewData["Title"] = "Daftar Alat";
    ViewData["ActivePage"] = "DaftarAlat";
}

<div class="p-4">

    <div class="mb-4">
        <h4 class="fw-bold">Ketersediaan Alat</h4>
        <p class="text-muted">
            Pantau stok alat yang tersedia secara real-time.
        </p>
    </div>

    <!-- SEARCH -->
    <div class="card border-0 shadow-sm mb-4 rounded-4">
        <div class="card-body">
            <input type="text"
                   id="searchBox"
                   class="form-control rounded-pill"
                   placeholder="Cari nama alat / kategori...">
        </div>
    </div>

    <!-- TABLE -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead class="table-light text-secondary small">
                        <tr>
                            <th>NAMA ALAT</th>
                            <th>KATEGORI</th>
                            <th class="text-center">STOK</th>
                            <th>STATUS</th>
                        </tr>
                    </thead>

                    <tbody id="tableBody">

                        @foreach (var a in Model.DataAlat)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">

                                        <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 me-3">
                                            <i class="bi bi-box-fill"></i>
                                        </div>

                                        <span class="fw-bold">
                                            @a.NamaAlat
                                        </span>

                                    </div>
                                </td>

                                <td class="text-muted">
                                    @a.NamaKategori
                                </td>

                                <td class="text-center">
                                    <span class="fw-bold @(a.Stok <= 2 ? "text-danger" : "text-dark")">
                                        @a.Stok
                                    </span>
                                </td>

                                <td>
                                    @if (a.Stok > 0)
                                    {
                                        <span class="badge bg-success-subtle text-success rounded-pill px-3">
                                            Tersedia
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger rounded-pill px-3">
                                            Habis
                                        </span>
                                    }
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>

<script>
document.getElementById("searchBox").addEventListener("keyup", function () {

    let keyword = this.value.toLowerCase();
    let rows = document.querySelectorAll("#tableBody tr");

    rows.forEach(row => {
        row.style.display =
            row.innerText.toLowerCase().includes(keyword)
            ? ""
            : "none";
    });
});
</script>