@page
@model PeminjamanAlat.Pages.Petugas.LaporanModel
@{
    Layout = "_LayoutPetugas";
    ViewData["Title"] = "Pusat Laporan";
    ViewData["ActivePage"] = "Laporan";
}

<div class="container-fluid p-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>
            <h3 class="fw-bold mb-1">Pusat Laporan</h3>
            <p class="text-muted mb-0">
                Rekap transaksi peminjaman selesai & ditolak
            </p>
        </div>

        <!-- BUTTON CETAK -->
        <button onclick="window.print()"
                class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-printer me-2"></i>
            Cetak Laporan
        </button>

    </div>

    <!-- SUMMARY -->
    <div class="row g-4 mb-4">

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-4 p-3 me-3">
                        <i class="bi bi-journal-text fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted">Total Transaksi</small>
                        <h3 class="fw-bold mb-0">@Model.TotalTransaksi</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="bg-success bg-opacity-10 text-success rounded-4 p-3 me-3">
                        <i class="bi bi-box-seam fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted">Total Alat Keluar</small>
                        <h3 class="fw-bold mb-0">@Model.TotalAlatKeluar</h3>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="row g-4">

        <!-- FILTER -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">

                    <h5 class="fw-bold mb-4">Filter Laporan</h5>

                    <form method="get">

                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Status</label>
                            <select name="status" class="form-select rounded-3">
                                <option value="">Semua Final</option>
                                <option value="2">Selesai</option>
                                <option value="Ditolak">Ditolak</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Tanggal Mulai</label>
                            <input type="date"
                                   name="mulai"
                                   class="form-control rounded-3">
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-semibold">Tanggal Selesai</label>
                            <input type="date"
                                   name="selesai"
                                   class="form-control rounded-3">
                        </div>

                        <button class="btn btn-dark w-100 rounded-pill">
                            Terapkan Filter
                        </button>

                    </form>

                </div>
            </div>
        </div>

        <!-- TABLE -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">

                    <div class="table-responsive">
                        <table class="table table-hover align-middle">

                            <thead class="table-light">
                                <tr>
                                    <th>Tanggal</th>
                                    <th>ID</th>
                                    <th>Peminjam</th>
                                    <th>Status</th>
                                </tr>
                            </thead>

                            <tbody>

                                @if (Model.LaporanData.Any())
                                {
                                    @foreach (var item in Model.LaporanData)
                                    {
                                        var selesai =
                                        item.Status == "2" ||
                                        item.Status == "Selesai";

                                        <tr>
                                            <td>
                                                @item.TanggalPinjam.ToString("dd/MM/yyyy")
                                            </td>

                                            <td class="fw-bold text-primary">
                                                #@item.IdPeminjaman
                                            </td>

                                            <td>
                                                @item.User?.Nama
                                            </td>

                                            <td>
                                                @if (selesai)
                                                {
                                                    <span class="badge bg-success rounded-pill px-3">
                                                        Selesai
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger rounded-pill px-3">
                                                        Ditolak
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            Tidak ada data ditemukan
                                        </td>
                                    </tr>
                                }

                            </tbody>

                        </table>
                    </div>

                </div>
            </div>
        </div>

    </div>

</div>

<style>
   @@media print {
        .btn, form, .col-lg-4, nav, .sidebar, .navbar

    {
        display: none !important;
    }

    .col-lg-8 {
        width: 100% !important;
    }

    body {
        background: white !important;
    }

    .card {
        box-shadow: none !important;
        border: 1px solid #ddd !important;
    }

    }
</style>