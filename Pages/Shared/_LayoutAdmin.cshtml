@{
    Layout = null;
    var activePage = ViewData["ActivePage"]?.ToString();
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            margin: 0;
            font-family: Inter,Segoe UI;
            background: #f8fafc
        }

        .sidebar {
            width: 270px;
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background: #fff;
            border-right: 1px solid #e5e7eb;
            padding: 28px
        }

        .logo {
            font-size: 28px;
            font-weight: 800;
            color: #111827
        }

        .logo-sub {
            color: #6b7280;
            font-size: 14px;
            margin-bottom: 30px
        }

        .menu-title {
            font-size: 12px;
            color: #9ca3af;
            font-weight: 700;
            margin-top: 25px;
            margin-bottom: 12px;
            text-transform: uppercase
        }

        .nav-link {
            padding: 13px 16px;
            border-radius: 14px;
            color: #374151;
            margin-bottom: 8px;
            font-weight: 500;
            transition: .2s;
            display: block;
            text-decoration: none
        }

            .nav-link:hover {
                background: #eef2ff;
                color: #4f46e5
            }

            .nav-link.active {
                background: #4f46e5;
                color: #fff !important;
                box-shadow: 0 10px 20px rgba(79,70,229,.2)
            }

            .nav-link i {
                margin-right: 10px
            }

        .main {
            margin-left: 270px
        }

        .topbar {
            background: #fff;
            height: 75px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 35px;
            border-bottom: 1px solid #e5e7eb
        }

        .user-box {
            font-weight: 600;
            color: #111827
        }

        .content {
            padding: 35px
        }

        .info-box {
            background: linear-gradient(135deg,#4f46e5,#6366f1);
            color: #fff;
            padding: 18px;
            border-radius: 18px;
            font-size: 14px;
            margin-top: 25px
        }

        .logout-box {
            position: absolute;
            bottom: 30px;
            left: 28px;
            right: 28px
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="logo">ADMIN</div>
        <div class="logo-sub">Inventory System</div>

        <div class="menu-title">Menu</div>

        <a asp-page="/Admin/Dashboard" class="nav-link @(activePage == "Dashboard" ? "active" : "")">
            <i class="bi bi-grid"></i> Dashboard
        </a>

        <a asp-page="/Admin/User" class="nav-link @(activePage == "User" ? "active" : "")">
            <i class="bi bi-people"></i> Kelola User
        </a>

        <a asp-page="/Admin/Alat" class="nav-link @(activePage == "Alat" ? "active" : "")">
            <i class="bi bi-tools"></i> Kelola Alat
        </a>

        <a asp-page="/Admin/Kategori" class="nav-link @(activePage == "Kategori" ? "active" : "")">
            <i class="bi bi-tags"></i> Kategori
        </a>

        @* <a asp-page="/Admin/Log" class="nav-link @(activePage == "Log" ? "active" : "")">
            <i class="bi bi-clock-history"></i> Log Aktivitas
        </a> *@

        <div class="info-box">
            <div class="fw-bold mb-1">Halo, @User.Identity?.Name</div>
            <div class="opacity-75">Kelola user, alat, kategori, dan pantau aktivitas sistem.</div>
        </div>

        <div class="logout-box">
            <form method="post" asp-page="/Logout">
                <button class="btn btn-danger w-100 rounded-pill">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </button>
            </form>
        </div>
    </div>

    <div class="main">
        <div class="topbar">
            <div class="fw-bold">Admin Dashboard</div>
            <div class="user-box">
                <i class="bi bi-person-circle me-1"></i> @User.Identity?.Name
            </div>
        </div>

        <div class="content">
            @RenderBody()
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>