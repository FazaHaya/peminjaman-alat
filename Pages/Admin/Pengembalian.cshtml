@page
@model PeminjamanAlat.Pages.Admin.PengembalianModel
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Kelola Pengembalian";
    ViewData["ActivePage"] = "Pengembalian";
}

<div class="container-fluid p-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Kelola Pengembalian</h3>
            <p class="text-muted mb-0">CRUD data pengembalian alat</p>
        </div>

        <button class="btn btn-primary rounded-pill px-4"
                onclick="openCreate()">
            <i class="bi bi-plus-circle me-2"></i>Tambah
        </button>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <input type="text"
                   id="searchBox"
                   class="form-control rounded-pill"
                   placeholder="Cari pengembalian...">
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>User</th>
                            <th>Alat</th>
                            <th>Tanggal</th>
                            <th>Kondisi</th>
                            <th>Denda</th>
                            <th class="text-center">Aksi</th>
                        </tr>
                    </thead>

                    <tbody id="tableBody">

                        @foreach (var x in Model.DataPengembalian)
                        {
                            <tr>
                                <td>@x.NamaUser</td>
                                <td>@x.NamaAlat</td>
                                <td>@x.Tanggal.ToString("dd MMM yyyy")</td>
                                <td>@x.Kondisi</td>
                                <td>Rp @x.TotalDenda.ToString("N0")</td>

                                <td class="text-center">

                                    <button class="btn btn-sm btn-outline-warning rounded-pill px-3"
                                            onclick="openEdit(
                                                    @x.IdPengembalian,
                                                    '@x.Tanggal.ToString("yyyy-MM-dd")',
                                                    '@x.Kondisi',
                                                    '@x.TotalDenda')">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    <button class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                            onclick="openDelete(@x.IdPengembalian)">
                                        <i class="bi bi-trash"></i>
                                    </button>

                                </td>
                            </tr>
                        }

                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>

<!-- CREATE -->
<div class="modal fade" id="modalCreate">
    <div class="modal-dialog">
        <div class="modal-content rounded-4 border-0">

            <form method="post" asp-page-handler="Create">

                <div class="modal-header">
                    <h5 class="fw-bold">Tambah Pengembalian</h5>
                </div>

                <div class="modal-body">

                    <select name="Input.IdPeminjaman" class="form-control mb-3">
                        <option value="">Pilih Transaksi</option>

                        @foreach (var p in Model.ListPinjam)
                        {
                            <option value="@p.IdPeminjaman">
                                #@p.IdPeminjaman - @p.User.Nama
                            </option>
                        }

                    </select>

                    <input type="date"
                           name="Input.TanggalDikembalikan"
                           class="form-control mb-3">

                    <select name="Input.KondisiKembali" placeholder="Kondisi"
                            class="form-control mb-3">

                        <option>Baik</option>
                        <option>Rusak Ringan</option>
                        <option>Rusak Berat</option>

                    </select>

                    <input type="number"
                           name="NominalDenda"
                           class="form-control"
                           placeholder="Nominal denda">

                </div>

                <div class="modal-footer">
                    <button class="btn btn-primary rounded-pill px-4">
                        Simpan
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- EDIT -->
<div class="modal fade" id="modalEdit">
    <div class="modal-dialog">
        <div class="modal-content rounded-4 border-0">

            <form method="post" asp-page-handler="Edit">

                <div class="modal-header">
                    <h5 class="fw-bold">Edit Pengembalian</h5>
                </div>

                <div class="modal-body">

                    <input type="hidden"
                           id="editId"
                           name="Input.IdPengembalian">

                    <input type="date"
                           id="editTanggal" 
                           name="Input.TanggalDikembalikan"
                           class="form-control mb-3">

                    <select id="editKondisi"
                            name="Input.KondisiKembali" 
                            class="form-control mb-3">

                        <option>Baik</option>
                        <option>Rusak Ringan</option>
                        <option>Rusak Berat</option>

                    </select>

                    <input type="number"
                           id="editDenda"
                           name="NominalDenda"
                           class="form-control">

                </div>

                <div class="modal-footer">
                    <button class="btn btn-warning rounded-pill px-4">
                        Update
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- DELETE -->
<div class="modal fade" id="modalDelete">
    <div class="modal-dialog">
        <div class="modal-content rounded-4 border-0">

            <form method="post" asp-page-handler="Delete">

                <div class="modal-header">
                    <h5 class="fw-bold">Hapus</h5>
                </div>

                <div class="modal-body">
                    <input type="hidden"
                           id="deleteId"
                           name="IdPengembalian">

                    <p>Yakin hapus data ini?</p>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-danger rounded-pill px-4">
                        Hapus
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    function openCreate(){
    new bootstrap.Modal(document.getElementById('modalCreate')).show();
    }

    function openDelete(id){
    deleteId.value=id;
    new bootstrap.Modal(document.getElementById('modalDelete')).show();
    }

    function openEdit(id,tgl,kondisi,denda){
    editId.value=id;
    editTanggal.value=tgl;
    editKondisi.value=kondisi;
    editDenda.value=denda;

    new bootstrap.Modal(document.getElementById('modalEdit')).show();
    }

    document.getElementById("searchBox").addEventListener("keyup", function(){

    let keyword=this.value.toLowerCase();
    let rows=document.querySelectorAll("#tableBody tr");

    rows.forEach(row=>{
    row.style.display=
    row.innerText.toLowerCase().includes(keyword)
    ? ""
    : "none";
    });

    });
</script>