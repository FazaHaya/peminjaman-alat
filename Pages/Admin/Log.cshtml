@page
@model PeminjamanAlat.Pages.Admin.LogModel
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Log Aktivitas";
    ViewData["ActivePage"] = "Log";
}

<div class="container-fluid p-4">

    <div class="mb-4">
        <h3 class="fw-bold mb-1">Log Aktivitas</h3>
        <p class="text-muted mb-0">Riwayat seluruh aktivitas sistem (read only)</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-6">
                    <input type="text"
                           id="searchBox"
                           class="form-control rounded-pill"
                           placeholder="Cari user / aktivitas...">
                </div>

                <div class="col-md-3">
                    <input type="date"
                           id="dateFilter"
                           class="form-control rounded-pill">
                </div>

                <div class="col-md-3">
                    <button class="btn btn-light border rounded-pill w-100"
                            onclick="resetFilter()">
                        Reset Filter
                    </button>
                </div>

            </div>

        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead class="table-light">
                        <tr>
                            <th style="width:20%">Waktu</th>
                            <th style="width:20%">User</th>
                            <th>Aktivitas</th>
                        </tr>
                    </thead>

                    <tbody id="tableBody">

                        @foreach (var x in Model.DataLog)
                        {
                            <tr data-date="@x.Waktu.ToString("yyyy-MM-dd")">

                                <td>
                                    <span class="fw-semibold">
                                        @x.Waktu.ToString("dd MMM yyyy")
                                    </span>
                                    <div class="small text-muted">
                                        @x.Waktu.ToString("HH:mm:ss")
                                    </div>
                                </td>

                                <td>
                                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3">
                                        @x.NamaUser
                                    </span>
                                </td>

                                <td>@x.Aktivitas</td>

                            </tr>
                        }

                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>

<script>
    const searchBox = document.getElementById("searchBox");
    const dateFilter = document.getElementById("dateFilter");

    searchBox.addEventListener("keyup", applyFilter);
    dateFilter.addEventListener("change", applyFilter);

    function applyFilter(){

        let keyword = searchBox.value.toLowerCase();
        let selectedDate = dateFilter.value;

        let rows = document.querySelectorAll("#tableBody tr");

        rows.forEach(row => {

            let textMatch =
                row.innerText.toLowerCase().includes(keyword);

            let dateMatch =
                selectedDate === "" ||
                row.getAttribute("data-date") === selectedDate;

            row.style.display =
                textMatch && dateMatch ? "" : "none";
        });
    }

    function resetFilter(){
        searchBox.value = "";
        dateFilter.value = "";
        applyFilter();
    }
</script>