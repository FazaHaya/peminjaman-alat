@page
@model PeminjamanAlat.API.Pages.Admin.DashboardModel
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Dashboard Admin";
    ViewData["ActivePage"] = "Dashboard";
}

<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1 text-dark">Dashboard Admin</h2>
            <p class="text-muted mb-0">
                Selamat datang kembali,
                <strong>@HttpContext.Session.GetString("UserName")</strong>
            </p>
        </div>

        <div class="d-flex align-items-center gap-3">

            <button class="btn btn-light rounded-circle shadow-sm position-relative"
                    style="width:45px;height:45px;">
                <i class="bi bi-bell fs-5"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                    3
                </span>
            </button>

            <img src="https://ui-avatars.com/api/?name=@HttpContext.Session.GetString("UserName")&background=4f46e5&color=fff"
                 width="45"
                 height="45"
                 class="rounded-circle shadow-sm" />

        </div>

    </div>

    <!-- WELCOME -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
        <div class="card-body p-4 text-white"
             style="background:linear-gradient(135deg,#4f46e5,#6366f1);">

            <div class="row align-items-center">

                <div class="col-md-8">
                    <h4 class="fw-bold">Panel Administrasi</h4>
                    <p class="mb-0 opacity-75">
                        Kelola user, alat, kategori, dan seluruh aktivitas sistem.
                    </p>
                </div>

                <div class="col-md-4 text-end d-none d-md-block">
                    <i class="bi bi-speedometer2"
                       style="font-size:70px;opacity:.25;"></i>
                </div>

            </div>

        </div>
    </div>

    <!-- STATS -->
    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small fw-bold mb-1">TOTAL USER</p>
                        <h2 class="fw-bold mb-0">@Model.TotalUsers</h2>
                    </div>

                    <div class="p-3 rounded-4"
                         style="background:#eef2ff;color:#4f46e5;">
                        <i class="bi bi-people fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small fw-bold mb-1">TOTAL ALAT</p>
                        <h2 class="fw-bold mb-0">@Model.TotalAlat</h2>
                    </div>

                    <div class="p-3 rounded-4"
                         style="background:#ecfdf5;color:#16a34a;">
                        <i class="bi bi-tools fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small fw-bold mb-1">PEMINJAMAN</p>
                        <h2 class="fw-bold mb-0">12</h2>
                    </div>

                    <div class="p-3 rounded-4"
                         style="background:#fff7ed;color:#ea580c;">
                        <i class="bi bi-box-seam fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small fw-bold mb-1">PENDING</p>
                        <h2 class="fw-bold mb-0">4</h2>
                    </div>

                    <div class="p-3 rounded-4"
                         style="background:#fef2f2;color:#dc2626;">
                        <i class="bi bi-clock-history fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- CONTENT -->
    <div class="row g-4">

        <!-- QUICK ACTION -->
        <div class="col-lg-4">

            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <h5 class="fw-bold mb-4">
                    <i class="bi bi-lightning-charge-fill text-warning me-2"></i>
                    Aksi Cepat
                </h5>

                <div class="d-grid gap-3">

                    <a href="/Admin/User"
                       class="btn btn-light border rounded-pill fw-semibold py-2">
                        <i class="bi bi-people me-2"></i> Kelola User
                    </a>

                    <a href="/Admin/Alat"
                       class="btn btn-light border rounded-pill fw-semibold py-2">
                        <i class="bi bi-tools me-2"></i> Kelola Alat
                    </a>

                    <a href="/Admin/Peminjaman"
                       class="btn btn-light border rounded-pill fw-semibold py-2">
                        <i class="bi bi-box-seam me-2"></i> Data Peminjaman
                    </a>

                </div>

            </div>

        </div>

        <!-- ACTIVITY -->
        <div class="col-lg-8">

            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-clock-history text-primary me-2"></i>
                        Aktivitas Terbaru
                    </h5>

                    <button class="btn btn-sm btn-light rounded-pill px-3 fw-semibold">
                        Lihat Semua
                    </button>
                </div>

                <div class="list-group list-group-flush">

                    <div class="list-group-item border-0 px-0 py-3">
                        <i class="bi bi-person-plus text-primary me-2"></i>
                        User baru berhasil ditambahkan
                    </div>

                    <div class="list-group-item border-0 px-0 py-3">
                        <i class="bi bi-tools text-success me-2"></i>
                        Data alat diperbarui admin
                    </div>

                    <div class="list-group-item border-0 px-0 py-3">
                        <i class="bi bi-box-seam text-warning me-2"></i>
                        Permintaan peminjaman baru masuk
                    </div>

                    <div class="list-group-item border-0 px-0 py-3">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        Pengembalian alat berhasil diverifikasi
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>