@page
@model PeminjamanAlat.Pages.Admin.PeminjamanModel
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Kelola Peminjaman";
    ViewData["ActivePage"] = "Peminjaman";
}

<div class="container-fluid p-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Kelola Peminjaman</h3>
            <p class="text-muted mb-0">CRUD transaksi peminjaman alat</p>
        </div>

        <button class="btn btn-primary rounded-pill px-4"
                onclick="openCreate()">
            <i class="bi bi-plus-circle me-2"></i>Tambah
        </button>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <input type="text"
                   id="searchBox"
                   class="form-control rounded-pill"
                   placeholder="Cari transaksi...">
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>User</th>
                            <th>Alat</th>
                            <th>Tgl Pinjam</th>
                            <th>Tgl Kembali</th>
                            <th>Status</th>
                            <th class="text-center">Aksi</th>
                        </tr>
                    </thead>

                    <tbody id="tableBody">

                        @foreach (var x in Model.DataPeminjaman)
                        {
                            <tr>
                                <td>@x.NamaUser</td>
                                <td>@x.NamaAlat</td>
                                <td>@x.TanggalPinjam.ToString("dd MMM yyyy")</td>
                                <td>@x.TanggalKembali.ToString("dd MMM yyyy")</td>

                                <td>
                                    @{
                                        var status = x.Status?.Trim() ?? "";

                                        var text = status switch
                                        {
                                            "0" => "Pending",
                                            "1" => "Dipinjam",
                                            "2" => "Selesai",
                                            "3" => "Menunggu Verifikasi",
                                            "4" => "Ditolak",

                                            "Pending" => "Pending",
                                            "Dipinjam" => "Dipinjam",
                                            "Selesai" => "Selesai",
                                            "Ditolak" => "Ditolak",
                                            "Menunggu Verifikasi" => "Menunggu Verifikasi",
                                            "Disetujui" => "Disetujui",

                                            _ => status
                                        };

                                        var color = text switch
                                        {
                                            "Pending" => "secondary",
                                            "Dipinjam" => "warning text-dark",
                                            "Selesai" => "success",
                                            "Ditolak" => "danger",
                                            "Menunggu Verifikasi" => "info text-dark",
                                            "Disetujui" => "primary",
                                            _ => "dark"
                                        };
                                    }

                                    <span class="badge bg-@color rounded-pill px-3">
                                        @text
                                    </span>
                                </td>

                                <td class="text-center">

                                    <button class="btn btn-sm btn-outline-warning rounded-pill px-3"
                                            onclick="openEdit(
                                                @x.IdPeminjaman,
                                                '@x.TanggalPinjam.ToString("yyyy-MM-dd")',
                                                '@x.TanggalKembali.ToString("yyyy-MM-dd")',
                                                '@x.Status')">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    <button class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                            onclick="openDelete(@x.IdPeminjaman)">
                                        <i class="bi bi-trash"></i>
                                    </button>

                                </td>
                            </tr>
                        }

                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>

<!-- CREATE -->
<div class="modal fade" id="modalCreate">
    <div class="modal-dialog">
        <div class="modal-content rounded-4 border-0">

            <form method="post" asp-page-handler="Create">

                <div class="modal-header">
                    <h5 class="fw-bold">Tambah Transaksi</h5>
                </div>

                <div class="modal-body">

                    <select name="Input.IdUser" class="form-control mb-3">
                        <option value="">Pilih User</option>
                        @foreach (var u in Model.ListUser)
                        {
                            <option value="@u.IdUser">@u.Nama</option>
                        }
                    </select>

                    <select name="SelectedAlat" class="form-control mb-3">
                        <option value="">Pilih Alat</option>
                        @foreach (var a in Model.ListAlat)
                        {
                            <option value="@a.IdAlat">@a.NamaAlat</option>
                        }
                    </select>

                    <input type="date"
                           name="Input.TanggalPinjam"
                           class="form-control mb-3">

                    <input type="date"
                           name="Input.TanggalKembali"
                           class="form-control mb-3">

                    <select name="Input.Status" class="form-control">
                        <option>Pending</option>
                        <option>Dipinjam</option>
                        <option>Selesai</option>
                        <option>Ditolak</option>
                    </select>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-primary rounded-pill px-4">
                        Simpan
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- EDIT -->
<div class="modal fade" id="modalEdit">
    <div class="modal-dialog">
        <div class="modal-content rounded-4 border-0">

            <form method="post" asp-page-handler="Edit">

                <div class="modal-header">
                    <h5 class="fw-bold">Edit Transaksi</h5>
                </div>

                <div class="modal-body">

                    <input type="hidden" id="editId" name="Input.IdPeminjaman">

                    <input type="date"
                           id="editPinjam"
                           name="Input.TanggalPinjam"
                           class="form-control mb-3">

                    <input type="date"
                           id="editKembali"
                           name="Input.TanggalKembali"
                           class="form-control mb-3">

                    <select id="editStatus"
                            name="Input.Status"
                            class="form-control">

                        <option>Pending</option>
                        <option>Dipinjam</option>
                        <option>Selesai</option>
                        <option>Ditolak</option>

                    </select>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-warning rounded-pill px-4">
                        Update
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- DELETE -->
<div class="modal fade" id="modalDelete">
    <div class="modal-dialog">
        <div class="modal-content rounded-4 border-0">

            <form method="post" asp-page-handler="Delete">

                <div class="modal-header">
                    <h5 class="fw-bold">Hapus</h5>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="deleteId" name="IdPeminjaman">
                    <p>Yakin hapus transaksi ini?</p>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-danger rounded-pill px-4">
                        Hapus
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    function openCreate(){
    new bootstrap.Modal(document.getElementById('modalCreate')).show();
    }

    function openDelete(id){
    deleteId.value=id;
    new bootstrap.Modal(document.getElementById('modalDelete')).show();
    }

    function openEdit(id,pinjam,kembali,status){
    editId.value=id;
    editPinjam.value=pinjam;
    editKembali.value=kembali;
    editStatus.value=status;

    new bootstrap.Modal(document.getElementById('modalEdit')).show();
    }

    document.getElementById("searchBox").addEventListener("keyup", function(){

    let keyword=this.value.toLowerCase();
    let rows=document.querySelectorAll("#tableBody tr");

    rows.forEach(row=>{
    row.style.display=
    row.innerText.toLowerCase().includes(keyword)
    ? ""
    : "none";
    });

    });
</script>