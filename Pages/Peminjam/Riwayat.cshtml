@page
@model PeminjamanAlat.Pages.Peminjam.PinjamanModel
@{
    Layout = "_LayoutPeminjam";
    ViewData["Title"] = "Pinjaman User";
    ViewData["ActivePage"] = "Riwayat";
}

<div class="p-5 bg-light" style="min-height:100vh;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold m-0">Riwayat Pinjaman</h4>
            <p class="text-muted small mb-0">
                Pantau status pinjaman alat kamu.
            </p>
        </div>

        <a asp-page="/Peminjam/Katalog"
           class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-lg me-2"></i>
            Pinjam Baru
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 border-0 shadow-sm mb-4">
            @TempData["Success"]
        </div>
    }

    @if (!Model.MyLoans.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 text-center py-5">
            <div class="card-body">
                <i class="bi bi-inboxes fs-1 text-muted"></i>
                <h5 class="mt-3 fw-bold text-muted">Belum ada pinjaman</h5>
            </div>
        </div>
    }

    <div class="row g-4">

        @foreach (var p in Model.MyLoans)
        {
            var status = (p.Status ?? "0").Trim();

            var badge = status switch
            {
                "0" => "secondary",
                "1" => "primary",
                "Disetujui" => "primary",
                "Dipinjam" => "primary",
                "2" => "success",
                "3" => "warning",
                "4" => "danger",
                _ => "dark"
            };

            var text = status switch
            {
                "0" => "Menunggu Persetujuan",
                "1" => "Sedang Dipinjam",
                "Disetujui" => "Sedang Dipinjam",
                "Dipinjam" => "Sedang Dipinjam",
                "2" => "Selesai",
                "3" => "Menunggu Verifikasi",
                "4" => "Ada Denda",
                _ => status
            };

            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4">

                    <div class="d-flex justify-content-between mb-3">
                        <span class="badge bg-@badge rounded-pill px-3 py-2">
                            @text
                        </span>

                        <small class="text-muted">
                            #@p.IdPeminjaman
                        </small>
                    </div>

                    <h5 class="fw-bold">@p.NamaAlat</h5>

                    <p class="text-muted small mb-4">
                        <i class="bi bi-calendar-event me-1"></i>
                        @p.TanggalPinjam?.ToString("dd MMM yyyy")
                    </p>

                    <div class="mt-auto">

                        @* MENUNGGU *@
                        @if (status == "0")
                        {
                            <div class="alert alert-light border rounded-4 small mb-0">
                                Menunggu persetujuan petugas.
                            </div>
                        }

                        @* STATUS DIPINJAM -> TAMPIL BUTTON *@
                        else if (
                        status == "1" ||
                        status == "Disetujui" ||
                        status == "Dipinjam")
                        {
                            <form method="post"
                                  asp-page-handler="AjukanKembali"
                                  asp-route-id="@p.IdPeminjaman">

                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="btn btn-dark w-100 rounded-pill py-2 fw-bold">
                                    <i class="bi bi-arrow-return-left me-2"></i>
                                    Ajukan Pengembalian
                                </button>

                            </form>
                        }

                        @* MENUNGGU VERIF *@
                        else if (status == "3")
                        {
                            <button class="btn btn-warning w-100 rounded-pill text-dark"
                                    disabled>
                                Menunggu Verifikasi Petugas
                            </button>
                        }

                        @* ADA DENDA *@
                        else if (status == "4")
                        {
                            <div class="border rounded-4 p-3 bg-danger bg-opacity-10">
                                <div class="fw-bold text-danger">
                                    Denda:
                                    Rp @p.TotalDenda.ToString("N0")
                                </div>

                                <small class="text-muted">
                                    Status: @p.StatusBayar
                                </small>
                            </div>
                        }

                        @* SELESAI *@
                        else
                        {
                            <div class="alert alert-success rounded-4 mb-0">
                                Transaksi selesai
                            </div>
                        }

                    </div>

                </div>
            </div>
        }

    </div>
</div>