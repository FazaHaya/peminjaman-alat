@page
@model PeminjamanAlat.Pages.Peminjam.KatalogModel
@{
    Layout = "_LayoutPeminjam";
    ViewData["Title"] = "Katalog Alat";
    ViewData["ActivePage"] = "Katalog";
}

<div class="flex-grow-1 p-5 bg-light" style="min-height: 100vh;">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold">Halo, @Model.NamaSiswa! 👋</h4>
            <p class="text-muted">Mau pinjam alat apa hari ini?</p>
        </div>
        <button class="btn btn-white shadow-sm rounded-pill px-4 border-0 bg-white" data-bs-toggle="modal" data-bs-target="#modalKeranjang">
            <i class="bi bi-cart3 me-2 text-primary"></i> Keranjang
            <span id="cartCount" class="badge bg-danger rounded-pill">0</span>
        </button>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="input-group shadow-sm rounded-pill overflow-hidden bg-white">
                <span class="input-group-text border-0 bg-white ps-3"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="pencarianAlat" class="form-control border-0 py-2" placeholder="Cari alat...">
            </div>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var alat in Model.DaftarAlat)
        {
            <div class="col-md-3 item-alat">
                <div class="card border-0 shadow-sm h-100 p-2" style="border-radius: 20px;">
                    <div class="bg-light rounded-4 text-center py-4 mb-3">
                        <i class="bi bi-box-seam display-4 text-secondary"></i>
                    </div>
                    <div class="card-body p-2">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h6 class="fw-bold m-0 nama-alat">@alat.NamaAlat</h6>
                            <span class="badge bg-success bg-opacity-10 text-success">@alat.Stok Tersedia</span>
                        </div>
                        <p class="small text-muted mb-3">@alat.Deskripsi</p>
                        <button onclick="tambahKeKeranjang(@alat.IdAlat, '@alat.NamaAlat')" class="btn btn-primary w-100 rounded-pill py-2">
                            + Pilih Alat
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="modalKeranjang" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 25px;">
            <div class="modal-header border-0 p-4 pb-0">
                <h5 class="fw-bold">Detail Pinjaman</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post">
                <div class="modal-body p-4">
                    <div id="isiKeranjang">
                        <p class="text-muted text-center py-3">Keranjang kosong</p>
                    </div>

                    <input type="hidden" id="SelectedAlatJson" name="SelectedAlatJson" />

                    <div class="row g-3 mt-2">
                        <div class="col-6">
                            <label class="small fw-bold mb-2">TANGGAL PINJAM</label>
                            <input asp-for="TglPinjam" type="date" class="form-control border-0 bg-light rounded-3" />
                        </div>
                        <div class="col-6">
                            <label class="small fw-bold mb-2">TANGGAL KEMBALI</label>
                            <input asp-for="TglKembali" type="date" class="form-control border-0 bg-light rounded-3" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 fw-bold shadow">Ajukan Sekarang</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let keranjang = [];

        function tambahKeKeranjang(id, nama) {
            if (keranjang.find(i => i.id === id)) return alert("Sudah ada!");
            keranjang.push({ id: id, nama: nama });
            updateUI();
        }

        function hapusItem(index) {
            keranjang.splice(index, 1);
            updateUI();
        }

        function updateUI() {
            document.getElementById('cartCount').innerText = keranjang.length;
            document.getElementById('SelectedAlatJson').value = JSON.stringify(keranjang.map(i => i.id));

            const container = document.getElementById('isiKeranjang');
            if (keranjang.length === 0) {
                container.innerHTML = '<p class="text-muted text-center py-3">Keranjang kosong</p>';
                return;
            }

            let html = '<div class="list-group list-group-flush">';
            keranjang.forEach((item, index) => {
                html += `<div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                            <span><i class="bi bi-check2-circle text-primary me-2"></i>${item.nama}</span>
                            <button type="button" onclick="hapusItem(${index})" class="btn btn-link text-danger p-0"><i class="bi bi-trash"></i></button>
                         </div>`;
            });
            container.innerHTML = html + '</div>';
        }

        // Search
        document.getElementById('pencarianAlat').addEventListener('input', function(e) {
            let kw = e.target.value.toLowerCase();
            document.querySelectorAll('.item-alat').forEach(card => {
                let nama = card.querySelector('.nama-alat').innerText.toLowerCase();
                card.style.display = nama.includes(kw) ? "block" : "none";
            });
        });
    </script>
}