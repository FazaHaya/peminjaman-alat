@page
@model PeminjamanAlat.Pages.Peminjam.DashboardModel
@{
    Layout = "_LayoutPeminjam";
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

<div class="container-fluid p-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>
            <h2 class="fw-bold mb-1">Dashboard Peminjam</h2>
            <p class="text-muted mb-0">
                Selamat datang kembali,
                <strong>@User.Identity?.Name</strong>
            </p>
        </div>

        <a href="/Peminjam/Katalog"
           class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-circle me-2"></i>
            Pinjam Alat
        </a>

    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
        <div class="card-body p-4 text-white"
             style="background:linear-gradient(135deg,#2563eb,#1d4ed8);">

            <div class="row align-items-center">

                <div class="col-md-8">
                    <h3 class="fw-bold mb-2">
                        Sistem Peminjaman Alat
                    </h3>

                    <p class="mb-0 opacity-75">
                        Pantau status peminjaman, ajukan pinjaman baru,
                        dan kelola riwayat peminjamanmu dengan mudah.
                    </p>
                </div>

                <div class="col-md-4 text-end d-none d-md-block">
                    <i class="bi bi-box-seam"
                       style="font-size:70px;opacity:.25;"></i>
                </div>

            </div>

        </div>
    </div>

    <div class="row g-4 mb-4">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted fw-semibold">
                            Sedang Dipinjam
                        </small>

                        <h2 class="fw-bold text-primary mt-2">
                            @Model.TotalAktif
                        </h2>
                    </div>

                    <div class="p-3 rounded-4 bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-box-arrow-up-right fs-4"></i>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted fw-semibold">
                            Menunggu Approval
                        </small>

                        <h2 class="fw-bold text-warning mt-2">
                            @Model.TotalPending
                        </h2>
                    </div>

                    <div class="p-3 rounded-4 bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-clock-history fs-4"></i>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted fw-semibold">
                            Total Riwayat
                        </small>

                        <h2 class="fw-bold text-success mt-2">
                            @Model.TotalRiwayat
                        </h2>
                    </div>

                    <div class="p-3 rounded-4 bg-success bg-opacity-10 text-success">
                        <i class="bi bi-check-circle fs-4"></i>
                    </div>
                </div>

            </div>
        </div>

    </div>

    <div class="row g-4">

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <h5 class="fw-bold mb-4">
                    <i class="bi bi-lightning-charge-fill text-warning me-2"></i>
                    Aksi Cepat
                </h5>

                <div class="d-grid gap-3">

                    <a href="/Peminjam/Katalog"
                       class="btn btn-light border rounded-pill py-2 fw-semibold">
                        <i class="bi bi-plus-circle me-2"></i>
                        Ajukan Pinjaman
                    </a>

                    <a href="/Peminjam/Pinjaman"
                       class="btn btn-light border rounded-pill py-2 fw-semibold">
                        <i class="bi bi-clock-history me-2"></i>
                        Riwayat Pinjaman
                    </a>

                    <a href="/Peminjam/Profile"
                       class="btn btn-light border rounded-pill py-2 fw-semibold">
                        <i class="bi bi-person-circle me-2"></i>
                        Profil Saya
                    </a>

                </div>

            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <h5 class="fw-bold mb-4">
                    <i class="bi bi-megaphone text-primary me-2"></i>
                    Informasi
                </h5>

                <div class="list-group list-group-flush">

                    <div class="list-group-item border-0 px-0 py-3">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        Pastikan alat dikembalikan tepat waktu.
                    </div>

                    <div class="list-group-item border-0 px-0 py-3">
                        <i class="bi bi-clock text-warning me-2"></i>
                        Pengajuan baru menunggu persetujuan petugas.
                    </div>

                    <div class="list-group-item border-0 px-0 py-3">
                        <i class="bi bi-shield-check text-primary me-2"></i>
                        Gunakan akun dengan aman dan jangan bagikan password.
                    </div>

                </div>

            </div>
        </div>

    </div>

</div>