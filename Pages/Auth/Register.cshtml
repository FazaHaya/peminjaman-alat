@page
@model PeminjamanAlat.API.Pages.Auth.RegisterModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar Akun - Inventory System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --primary: #4f46e5;
            --secondary: #6366f1;
            --light: #f8faff;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg,#eef2ff,#f8faff);
            display: flex;
            align-items: center;
            font-family: 'Segoe UI',sans-serif;
        }

        .register-card {
            border: none;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,.08);
        }

        .left-panel {
            background: linear-gradient(160deg,#4f46e5,#6366f1);
            color: white;
            padding: 50px 35px;
            height: 100%;
        }

            .left-panel h2 {
                font-weight: 700;
            }

            .left-panel p {
                opacity: .9;
            }

        .right-panel {
            padding: 45px 35px;
            background: white;
        }

        .logo-box {
            width: 65px;
            height: 65px;
            border-radius: 18px;
            background: rgba(255,255,255,.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin-bottom: 25px;
        }

        .form-control {
            height: 50px;
            border-radius: 14px;
            border: 1px solid #dbeafe;
            background: #f8faff;
        }

            .form-control:focus {
                box-shadow: none;
                border-color: var(--primary);
                background: white;
            }

        .input-group-text {
            border-radius: 14px 0 0 14px;
            background: #f8faff;
            border: 1px solid #dbeafe;
            border-right: none;
        }

        .btn-register {
            height: 50px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg,#4f46e5,#6366f1);
            font-weight: 600;
            transition: .3s;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 24px rgba(79,70,229,.25);
            }

        .small-link {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }

            .small-link:hover {
                color: #312e81;
            }

        .title {
            font-weight: 700;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">

                <div class="card register-card">
                    <div class="row g-0">

                        <!-- kiri -->
                        <div class="col-md-5 d-none d-md-block">
                            <div class="left-panel">

                                <div class="logo-box">
                                    <i class="bi bi-box-seam"></i>
                                </div>

                                <h2>Gabung Sekarang</h2>
                                <p class="mt-3">
                                    Buat akun baru untuk mengakses sistem peminjaman alat,
                                    cek status pinjaman, dan kelola kebutuhan inventaris dengan mudah.
                                </p>

                                <div class="mt-5">
                                    <i class="bi bi-shield-check fs-2"></i>
                                    <p class="mt-2 mb-0">Data aman & sistem modern</p>
                                </div>

                            </div>
                        </div>

                        <!-- kanan -->
                        <div class="col-md-7">
                            <div class="right-panel">

                                <h3 class="title mb-2">Buat Akun Baru</h3>
                                <p class="text-muted mb-4">
                                    Isi data di bawah untuk mendaftar.
                                </p>

                                @if (Model.Msg != null)
                                {
                                    <div class="alert alert-danger border-0 rounded-4 small">
                                        <i class="bi bi-exclamation-circle me-2"></i>
                                        @Model.Msg
                                    </div>
                                }

                                <form method="post">

                                    @Html.AntiForgeryToken()

                                    <div class="mb-3">
                                        <label class="fw-semibold mb-2">Nama Lengkap</label>
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="bi bi-person"></i>
                                            </span>
                                            <input asp-for="Input.Nama"
                                                   class="form-control"
                                                   placeholder="Masukkan nama lengkap"
                                                   required />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="fw-semibold mb-2">Username</label>
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="bi bi-at"></i>
                                            </span>
                                            <input asp-for="Input.Username"
                                                   class="form-control"
                                                   placeholder="Masukkan username"
                                                   required />
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="fw-semibold mb-2">Password</label>
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="bi bi-lock"></i>
                                            </span>
                                            <input asp-for="Input.Password"
                                                   type="password"
                                                   class="form-control"
                                                   placeholder="Masukkan password"
                                                   required />
                                        </div>
                                    </div>

                                    <button type="submit"
                                            class="btn btn-primary w-100 btn-register">
                                        Daftar Sekarang
                                        <i class="bi bi-arrow-right ms-2"></i>
                                    </button>

                                    <div class="text-center mt-4">
                                        <span class="text-muted">Sudah punya akun?</span>
                                        <a href="/Auth/Login" class="small-link ms-1">
                                            Login disini
                                        </a>
                                    </div>

                                </form>

                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>

</body>
</html>