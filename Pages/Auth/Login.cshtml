@page
@model LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        body {
            background: linear-gradient(135deg,#f5f7ff,#e4e8ff);
            height: 100vh;
            display: flex;
            align-items: center;
            font-family: Segoe UI;
        }

        .login-card {
            border: none;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,.05);
            padding: 40px;
            background: white;
        }

        .logo-circle {
            width: 60px;
            height: 60px;
            background: #eef2ff;
            color: #4f46e5;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: auto;
            font-size: 28px;
            margin-bottom: 15px;
        }

        .form-control {
            padding: 12px;
            border-radius: 12px;
        }

        .btn-login {
            background: #4f46e5;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-4">

                <div class="card login-card">

                    <div class="text-center mb-4">
                        <div class="logo-circle">
                            <i class="bi bi-person-lock"></i>
                        </div>

                        <h4 class="fw-bold">Selamat Datang</h4>
                        <p class="text-muted small">Silakan login ke akun anda</p>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Msg))
                    {
                        <div class="alert alert-danger small">
                            @Model.Msg
                        </div>
                    }

                    <form method="post">

                        <div class="mb-3">
                            <label>Username</label>
                            <input asp-for="Username" class="form-control" required />
                        </div>

                        <div class="mb-4">
                            <label>Password</label>
                            <input asp-for="Password" type="password" class="form-control" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-login">
                            Masuk Sekarang
                        </button>
                        <div class="text-center mt-4">
                            <span class="text-muted small">Belum punya akun? </span>
                            <a href="/Auth/Register" class="text-decoration-none small fw-bold" style="color: var(--primary-color);">Daftar</a>
                        </div>
                    </form>

                </div>

            </div>
        </div>
    </div>

</body>
</html>